{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/queue/inpi-catalog-sync/route.ts": {
      "experimentalTriggers": [
        {
          "type": "queue/v2beta",
          "topic": "inpi-catalog-sync",
          "retryAfterSeconds": 15,
          "initialDelaySeconds": 0
        }
      ]
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup-documents",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/check-deadlines",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/check-contracts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/check-documents",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/check-event-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/internal/module-detect",
      "schedule": "0 * * * *"
    }
  ]
}
