{
  "name": "magic-lawyer",
  "version": "1.0.14-beta.3",
  "private": true,
  "scripts": {
    "dev": "cross-env PORT=9192 next dev --turbopack",
    "dev:ngrok": "concurrently \"npm run dev\" \"ngrok http 9192\"",
    "dev:asaas": "concurrently \"npm run dev\" \"ngrok http 9192\" \"node scripts/wait-and-cleanup.js\"",
    "build": "prisma generate && npm run repo:hygiene && next build",
    "build:turbopack": "prisma generate && npm run repo:hygiene && next build",
    "build:webpack": "prisma generate && next build --webpack",
    "postinstall": "prisma generate",
    "start": "cross-env PORT=9192 next start",
    "lint": "eslint --fix",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:reset": "docker compose -f docker-compose.db.yml down -v && docker compose -f docker-compose.db.yml up -d",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "prisma:seed:recebimentos": "node prisma/seed.js --with-recebimentos",
    "redis:start": "redis-cli ping >/dev/null 2>&1 || redis-server --daemonize yes",
    "redis:stop": "redis-cli shutdown || true",
    "redis:check": "redis-cli ping",
    "services:up": "npm run db:up && npm run redis:start",
    "services:down": "npm run redis:stop && npm run db:down",
    "setup": "npm install && npm run services:up && npm run prisma:push && npm run prisma:seed",
    "setup:dev": "npm run setup && npm run dev",
    "reset:dev": "npm run services:up && cross-env PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=YES prisma db push --force-reset --accept-data-loss && npm run prisma:seed",
    "clean": "npm run db:down && rm -rf node_modules && rm -rf .next",
    "clean:artifacts": "rm -rf .playwright-cli output/playwright playwright-report test-results",
    "cleanup:asaas": "node scripts/cleanup-asaas.js",
    "notifications:test": "npx tsx scripts/test-notifications.ts",
    "notifications:smoke": "npx tsx scripts/smoke-test-notifications.ts",
    "notifications:webhook": "npx tsx scripts/test-asaas-webhook.ts",
    "notifications:crons": "curl -sSf -X GET \"http://localhost:9192/api/cron/check-deadlines\" -H \"Authorization: Bearer ${CRON_SECRET:-test-secret}\" > /dev/null && curl -sSf -X GET \"http://localhost:9192/api/cron/check-contracts\" -H \"Authorization: Bearer ${CRON_SECRET:-test-secret}\" > /dev/null",
    "notifications:all": "npm run notifications:test && npm run notifications:webhook && npm run notifications:smoke && npm run notifications:crons",
    "notifications:repair": "npx tsx scripts/fix-tenant-status-simple.ts",
    "jusbrasil:backfill:process-monitors": "npx tsx scripts/jusbrasil-backfill-process-monitors.ts",
    "jusbrasil:backfill:prazos": "npx tsx scripts/backfill-jusbrasil-prazos.ts",
    "polling:status": "npx tsx scripts/polling-control.ts --status",
    "polling:off": "npx tsx scripts/polling-control.ts --off",
    "polling:on": "npx tsx scripts/polling-control.ts --on",
    "polling:smoke": "POLLING_LOAD_MODE=smoke npx tsx scripts/load-test-10k-sessoes.ts --smoke",
    "polling:load": "POLLING_LOAD_MODE=load npx tsx scripts/load-test-10k-sessoes.ts --load",
    "modules:detect": "npx tsx scripts/auto-detect-modules.ts",
    "guard:hard-delete": "node scripts/check-prisma-hard-delete.mjs",
    "repo:hygiene": "npm run guard:hard-delete && node scripts/repo-hygiene.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
