# NextAuth / Auth.js
NEXTAUTH_URL=http://localhost:9192
NEXTAUTH_SECRET=defina_um_valor_seguro

# Banco (Docker Compose expõe porta 8567 → 5432 interno)
DATABASE_URL=postgresql://magiclawyer:MagicLawyer@2025@localhost:8567/magic_lawyer?schema=magiclawyer

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Realtime (Ably)
ABLY_API_KEY=coloque_sua_chave
NEXT_PUBLIC_ABLY_CLIENT_KEY=coloque_sua_chave_publica
# NEXT_PUBLIC_POLLING_ENABLED: controle runtime fica travado em ambiente runtime se definido
# Não definir em produção. Use controle operacional via API + secret.
# NEXT_PUBLIC_POLLING_ENABLED=true
REALTIME_CHANNEL_PREFIX=ml-dev
NEXT_PUBLIC_REALTIME_CHANNEL_PREFIX=ml-dev
REALTIME_INTERNAL_TOKEN=gerar_token_seguro
# Chave opcional de controle operacional para desligar polling global em incidentes
POLLING_CONTROL_BASE_URL=http://localhost:9192
POLLING_CONTROL_SECRET=

# Sistema de Notificações
NOTIFICATION_USE_NEW_SYSTEM=true

# Email (fallback global; credenciais por tenant ficam no banco)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Magic Lawyer <noreply@seudominio.com>

# Crons e integrações externas
CRON_SECRET=defina_cron_secret
ASAAS_API_KEY=sua_api_key
ASAAS_WEBHOOK_SECRET=segredo_webhook

# Causas (catálogo jurídico)
# URL de endpoint JSON com lista oficial de causas.
# Formatos aceitos:
# 1) array: [{ "nome": "...", "codigoCnj": "...", "descricao": "..." }]
# 2) objeto com propriedade `causas`: [{ ... }, ...]
# Em produção/rede interna, recomendamos apontar para o endpoint interno:
# /api/causas-oficiais/cnj
# Exemplo dev: http://localhost:9192/api/causas-oficiais/cnj
CAUSAS_OFICIAIS_URL=/api/causas-oficiais/cnj

# Criptografia de certificados digitais (32 bytes hex — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CERT_ENCRYPTION_KEY=

# Integracoes PJe / Comunica
COMUNICA_API_BASE_URL=https://comunicaapi.pje.jus.br
# COMUNICA_LOGIN=seu_login
# COMUNICA_PASSWORD=sua_senha
# COMUNICA_ALLOW_ANON_TEST=true
# COMUNICA_CA_CERT=cole_o_certificado_PEM_ou_base64
# COMUNICA_CA_CERT_PATH=/caminho/para/ca.pem
# COMUNICA_TLS_INSECURE=false

# Scraping e-SAJ (recomendado habilitar TLS legacy para TJBA)
ESAJ_TLS_INSECURE=true
ESAJ_TLS_MIN_VERSION=TLSv1
ESAJ_TLS_LEGACY=true
ESAJ_MAX_OAB_PAGES=5
ESAJ_MAX_OAB_PROCESSOS=100

# Load test de polling (smoke/load)
POLLING_LOAD_BASE_URL=http://localhost:9192
POLLING_LOAD_ENDPOINT=/api/internal/session/validate
POLLING_LOAD_DURATION_SECONDS=60
POLLING_LOAD_SESSION_COUNT=10000
POLLING_LOAD_INTERVAL_MS=30000
POLLING_LOAD_MAX_INFLIGHT=800
POLLING_LOAD_REPORT_EVERY_MS=5000

# Importação automática de processos
# IMPORT_PROCESSO_MAX_BATCH=100
