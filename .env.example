# =====================
# MAGIC LAWYER - .env TEMPLATE
# =====================
# Baseado em: 03/03/2026
# Regra: manter organizado por domínio e usar placeholders no local.
# =====================

# =====================
# CORE
# =====================
# NextAuth
NEXTAUTH_URL=http://localhost:9192
NEXTAUTH_SECRET=defina_um_valor_seguro

# Database
# OBS: local via Docker Compose 8567 -> 5432 interno
DATABASE_URL=postgresql://magiclawyer:MagicLawyer@2025@localhost:8567/magic_lawyer?schema=magiclawyer

# Fila / cache
REDIS_URL=redis://localhost:6379

# =====================
# AUTH / SESSION (interno)
# =====================
FIRST_ACCESS_TOKEN_SECRET=
INTERNAL_API_TOKEN=
INTERNAL_ADMIN_TOKEN=

# =====================
# APP/RENDER URLs
# =====================
BASE_URL=http://localhost:9192
NEXT_PUBLIC_APP_URL=
VERCEL_URL=

# =====================
# REAIS / NOTIFICAÇÕES (produção)
# =====================
ABLY_API_KEY=coloque_sua_chave
NEXT_PUBLIC_ABLY_CLIENT_KEY=coloque_sua_chave_publica
REALTIME_CHANNEL_PREFIX=ml-dev
NEXT_PUBLIC_REALTIME_CHANNEL_PREFIX=ml-dev
REALTIME_INTERNAL_TOKEN=gerar_token_seguro
NOTIFICATION_USE_NEW_SYSTEM=true

# =====================
# EMAIL / TRANSACTIONAL
# =====================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Magic Lawyer <noreply@seudominio.com>

# =====================
# PAGAMENTOS / FINANCEIRO
# =====================
CRON_SECRET=defina_cron_secret
ASAAS_API_KEY=sua_api_key
ASAAS_WEBHOOK_SECRET=segredo_webhook
ASAAS_ENVIRONMENT=staging

# =====================
# CRYPTO / DOCUMENTOS
# =====================
# 64 chars hex (32 bytes) recomendado
CERT_ENCRYPTION_KEY=defina_64_chars_hex
ENCRYPTION_KEY=

# =====================
# OAB / JUDICIAL INTEGRATIONS
# =====================
COMUNICA_API_BASE_URL=https://comunicaapi.pje.jus.br
# COMUNICA_LOGIN=seu_login
# COMUNICA_PASSWORD=sua_senha
# COMUNICA_SENHA=seu_token_ou_senha_alt
# COMUNICA_ALLOW_ANON_TEST=false
# COMUNICA_CA_CERT=cole_o_certificado_pem_ou_base64
# COMUNICA_CA_CERT_PATH=/caminho/para/ca.pem
# COMUNICA_TLS_INSECURE=false

ESAJ_TLS_INSECURE=true
ESAJ_TLS_MIN_VERSION=TLSv1
ESAJ_TLS_LEGACY=true
ESAJ_MAX_OAB_PAGES=5
ESAJ_MAX_OAB_PROCESSOS=100

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

CLICKSIGN_API_BASE=https://sandbox.clicksign.com/api/v1
CLICKSIGN_ACCESS_TOKEN=

# =====================
# STORAGE / UPLOADS
# =====================
# Cloudinary (substitua por sua conta real)
CLOUDINARY_CLOUD_NAME=seu-cloud-name
CLOUDINARY_API_KEY=seu-api-key
CLOUDINARY_API_SECRET=seu-api-secret
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# =====================
# INTEGRAÇÕES LEGAIS / CATALÓGOS
# =====================
# Causas Oficiais (catálogo CNJ)
CAUSAS_OFICIAIS_URL=/api/causas-oficiais/cnj

# =====================
# MAPA / MODULOS INTERNOS
# =====================
MODULE_DETECT_INTERNAL_TOKEN=
MODULE_MAP_API_TOKEN=

# =====================
# MODOS OPERACIONAIS (debug / carga)
# =====================
# Polling de fallback (opcional)
POLLING_CONTROL_BASE_URL=http://localhost:9192
POLLING_CONTROL_SECRET=
# NEXT_PUBLIC_POLLING_ENABLED=true
# NEXT_PUBLIC_POLLING_OFF=false

# =====================================
# HIGH-LOAD / REPRODUÇÃO DE TESTE (opcional)
# =====================================
POLLING_LOAD_BASE_URL=http://localhost:9192
POLLING_LOAD_ENDPOINT=/api/internal/session/validate
POLLING_LOAD_DURATION_SECONDS=60
POLLING_LOAD_SESSION_COUNT=10000
POLLING_LOAD_INTERVAL_MS=30000
POLLING_LOAD_MAX_INFLIGHT=800
POLLING_LOAD_REPORT_EVERY_MS=5000

# =====================
# PROCESSAMENTO EM LOTE
# =====================
# IMPORT_PROCESSO_MAX_BATCH=100

# =====================
# FEATURE FLAGS ÚTEIS
# =====================
LOG_SILENT=false
TEST_MODE=false

# =====================
# OBSERVAÇÕES
# =====================
# 1) Variáveis comentadas só para referência não devem ir com chave em branco no ambiente real.
# 2) Em produção, preferir Secret Manager e não versionar segredos reais.
# 3) Para ambiente local, copie este arquivo para .env e ajuste apenas o necessário.
